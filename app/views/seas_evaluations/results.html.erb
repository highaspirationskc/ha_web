<% score_labels = { 0 => "Not doing this at all", 1 => "Doing this inconsistently", 2 => "Doing this as expected", 3 => "Doing this consistently and helping others" } %>

<div class="max-w-4xl mx-auto py-6 sm:px-6 lg:px-8">
  <div class="px-4 py-6 sm:px-0">
    <!-- Header -->
    <div class="mb-6">
      <h1 class="text-2xl font-bold text-gray-900">SEAS Self Evaluation</h1>
      <p class="text-sm text-gray-500 mt-1"><%= @evaluation.evaluation_year %></p>
      <div class="mt-2 flex items-center space-x-3">
        <% if @evaluation.status == "reviewed" %>
          <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-green-100 text-green-800">Reviewed</span>
        <% elsif @evaluation.status == "in_review" %>
          <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-blue-100 text-blue-800">In Review</span>
        <% else %>
          <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-amber-100 text-amber-800">Submitted</span>
        <% end %>
      </div>
    </div>

    <!-- Domains -->
    <% @domains.each do |domain| %>
      <div class="bg-white shadow sm:rounded-lg overflow-hidden mb-6">
        <div class="px-6 py-4 bg-gray-50 border-b border-gray-200">
          <h3 class="text-lg font-semibold text-gray-900"><%= domain["name"] %></h3>
        </div>

        <div class="divide-y divide-gray-200">
          <% domain["questions"].sort_by { |q| q["position"] }.each do |question| %>
            <% response = @responses_by_question[question["id"]] %>
            <% score = question["score"] || response&.score %>
            <% next unless score %>
            <div class="px-6 py-5">
              <p class="text-sm font-medium text-gray-900 mb-3"><%= question["text"] %></p>

              <!-- Score display -->
              <div class="space-y-2">
                <% (0..3).each do |s| %>
                  <div class="flex items-center space-x-2">
                    <div class="h-4 w-4 rounded-full border-2 flex items-center justify-center <%= score == s ? 'border-indigo-600' : 'border-gray-300' %>">
                      <% if score == s %>
                        <div class="h-2 w-2 rounded-full bg-indigo-600"></div>
                      <% end %>
                    </div>
                    <span class="text-sm <%= score == s ? 'text-gray-900 font-medium' : 'text-gray-500' %>">
                      <%= s %> <%= score_labels[s] %>
                    </span>
                  </div>
                <% end %>
              </div>

              <% review_action = question["review_action"] || response&.review_action %>
              <% if review_action.present? %>
                <div class="mt-4 bg-gray-50 rounded-lg p-3">
                  <div class="flex items-center space-x-2 mb-1">
                    <span class="text-xs font-medium text-gray-500 uppercase">Reviewer:</span>
                    <% if review_action == "confirmed" %>
                      <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-green-100 text-green-800">Confirmed</span>
                    <% elsif review_action == "adjusted" %>
                      <% adj_score = question["adjusted_score"] || response&.adjusted_score %>
                      <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-amber-100 text-amber-800">
                        Adjusted to: <%= adj_score %> &mdash; <%= score_labels[adj_score] %>
                      </span>
                    <% end %>
                  </div>
                  <% feedback = question["feedback"] || response&.feedback %>
                  <% if feedback.present? %>
                    <p class="text-sm text-gray-600 mt-1"><%= feedback %></p>
                  <% end %>
                </div>
              <% end %>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</div>
