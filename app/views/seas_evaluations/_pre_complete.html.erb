<% score_labels = { 0 => "Not doing this at all", 1 => "Doing this inconsistently", 2 => "Doing this as expected", 3 => "Doing this consistently and helping others" } %>

<!-- Back link -->
<div class="mb-6">
  <% last_position = @domains.map { |d| d["position"] }.max %>
  <%= link_to seas_evaluation_path(@evaluation.token, step: last_position || 1), class: "inline-flex items-center text-sm text-gray-500 hover:text-gray-700" do %>
    <svg class="h-5 w-5 mr-1" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5" />
    </svg>
    Back
  <% end %>
</div>

<div class="bg-white shadow sm:rounded-lg overflow-hidden">
  <div class="px-6 py-5 border-b border-gray-200">
    <h2 class="text-xl font-bold text-gray-900">Review Your Answers</h2>
    <p class="text-sm text-gray-500 mt-1">Take a moment to review before submitting.</p>
  </div>

  <div class="divide-y divide-gray-200">
    <% @domains.sort_by { |d| d["position"] }.each do |domain| %>
      <div class="px-6 py-4">
        <h3 class="text-sm font-semibold text-gray-900 uppercase tracking-wider mb-3"><%= domain["name"] %></h3>
        <div class="space-y-2">
          <% domain["questions"].sort_by { |q| q["position"] }.each do |question| %>
            <% response = @responses_by_question[question["id"]] %>
            <div class="flex items-center justify-between text-sm">
              <span class="text-gray-700 flex-1 mr-4"><%= question["text"] %></span>
              <span class="flex-shrink-0 font-medium text-gray-900">
                <%= response&.score %> &mdash; <%= score_labels[response&.score] %>
              </span>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>

  <div class="px-6 py-4 bg-gray-50">
    <%= button_to "Submit Evaluation", seas_evaluation_complete_path(@evaluation.token), method: :post, class: "w-full inline-flex justify-center items-center px-6 py-3 border border-transparent text-base font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700 cursor-pointer" %>
  </div>
</div>
