<%
  domain_names = @domains&.sort_by { |d| d["position"] }&.map { |d| d["name"] } || []
  total_questions = @domains&.sum { |d| d["questions"].size } || 0
  domain_count = domain_names.size
  questions_per_domain = domain_count > 0 ? total_questions / domain_count : 0

  if domain_names.size > 1
    domain_list = domain_names[0..-2].map { |n| "<strong>#{ERB::Util.html_escape(n)}</strong>" }.join(", ") +
                  ", and <strong>#{ERB::Util.html_escape(domain_names.last)}</strong>"
  elsif domain_names.size == 1
    domain_list = "<strong>#{ERB::Util.html_escape(domain_names.first)}</strong>"
  else
    domain_list = ""
  end

  count_word = { 1 => "one", 2 => "two", 3 => "three", 4 => "four", 5 => "five", 6 => "six" }[domain_count] || domain_count.to_s
%>

<div class="bg-white shadow sm:rounded-lg overflow-hidden">
  <% if @welcome_image.present? %>
    <%= image_tag @welcome_image.url, alt: "SEAS Evaluation", class: "w-full h-48 sm:h-64 object-cover" %>
  <% end %>
  <div class="px-6 py-8">
    <h1 class="text-2xl font-bold text-gray-900 mb-1">Hey, <%= @mentee.user.first_name %></h1>
    <p class="text-gray-500 mb-6">It's time for your SEAS Evaluation!</p>

    <div class="text-gray-700 space-y-4">
      <% if domain_names.any? %>
        <p>
          <strong>SEAS</strong> is a way to check in on how you're doing across <%= count_word %> parts of
          your life: <%= domain_list.html_safe %>.
        </p>
        <p>
          You'll answer <%= total_questions %> total questions (<%= questions_per_domain %> per domain). Each one is scored
          0&ndash;3 based on how true it is for you right now.
        </p>
      <% end %>

      <p>Score guide:</p>
      <ul class="list-disc list-inside space-y-1">
        <li>0 Not doing this at all</li>
        <li>1 Doing this inconsistently</li>
        <li>2 Doing this as expected</li>
        <li>3 Doing this consistently and helping others</li>
      </ul>

      <p>If you're stuck between two scores, pick the lower score.</p>
    </div>
  </div>
</div>

<div class="mt-8">
  <p class="font-semibold text-gray-900 mb-3">Ready to get started?</p>
  <%= link_to seas_evaluation_path(@evaluation.token, step: 1), class: "inline-flex justify-center items-center px-12 py-3 border border-transparent text-base font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700" do %>
    Begin
  <% end %>
</div>
