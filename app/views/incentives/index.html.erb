<div class="max-w-7xl mx-auto py-6 sm:px-6 lg:px-8">
  <div class="px-4 py-6 sm:px-0">
    <%# Header %>
    <div class="mb-2">
      <h1 class="text-3xl font-bold text-gray-900">Incentives</h1>
      <p class="mt-1 text-sm text-gray-500">Upload, manage, and see what mentees connect with</p>
    </div>

    <%# Filters and New button %>
    <div class="flex items-center justify-between mb-6 mt-4">
      <div class="flex items-center gap-2">
        <%= link_to incentives_path,
            class: "inline-flex items-center px-5 py-2 text-xs font-bold rounded-lg #{@current_filter == 'all' ? 'bg-gray-900 text-gray-200' : 'bg-black/10 text-gray-600 hover:bg-black/20'}" do %>
          All
        <% end %>
        <%= link_to incentives_path(filter: "team"),
            class: "inline-flex items-center px-5 py-2 text-xs font-bold rounded-lg #{@current_filter == 'team' ? 'bg-gray-900 text-gray-200' : 'bg-black/10 text-gray-600 hover:bg-black/20'}" do %>
          Team
        <% end %>
        <%= link_to incentives_path(filter: "individual"),
            class: "inline-flex items-center px-5 py-2 text-xs font-bold rounded-lg #{@current_filter == 'individual' ? 'bg-gray-900 text-gray-200' : 'bg-black/10 text-gray-600 hover:bg-black/20'}" do %>
          Individual
        <% end %>
      </div>

      <% if current_user.can?(:create, :incentives) %>
        <%= link_to new_incentive_path, class: "inline-flex items-center px-6 py-2.5 text-xs font-bold rounded-full bg-indigo-600 text-gray-200 hover:bg-indigo-700" do %>
          New Incentive
        <% end %>
      <% end %>
    </div>

    <% if notice.present? %>
      <div class="mb-4 rounded-md bg-green-50 p-4">
        <p class="text-sm font-medium text-green-800"><%= notice %></p>
      </div>
    <% end %>

    <% if alert.present? %>
      <div class="mb-4 rounded-md bg-red-50 p-4">
        <p class="text-sm font-medium text-red-800"><%= alert %></p>
      </div>
    <% end %>

    <%# Incentives table %>
    <div class="bg-white shadow overflow-hidden sm:rounded-lg">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-100">
          <tr>
            <th scope="col" class="px-6 py-3 text-left text-xs font-bold text-gray-500 uppercase tracking-wider">Incentive</th>
            <th scope="col" class="px-6 py-3 text-center text-xs font-bold text-gray-500 uppercase tracking-wider">Point Cost</th>
            <th scope="col" class="px-6 py-3 text-center text-xs font-bold text-gray-500 uppercase tracking-wider">Team/Individual</th>
            <th scope="col" class="px-6 py-3 text-center text-xs font-bold text-gray-500 uppercase tracking-wider">Status</th>
            <th scope="col" class="px-6 py-3 text-right text-xs font-bold text-gray-500 uppercase tracking-wider"></th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
          <% if @incentives.empty? %>
            <tr>
              <td colspan="5" class="px-6 py-8 text-center text-gray-500">No incentives found.</td>
            </tr>
          <% else %>
            <% @incentives.each do |incentive| %>
              <tr class="hover:bg-gray-50 <%= 'opacity-65' unless incentive.active? %>">
                <%# Incentive: image + name + description %>
                <td class="px-6 py-4 whitespace-nowrap">
                  <div class="flex items-center">
                    <div class="flex-shrink-0 h-14 w-14 rounded bg-gray-200 overflow-hidden">
                      <% if incentive.image.present? %>
                        <img src="<%= incentive.image.thumbnail_url %>" alt="<%= incentive.name %>" class="h-14 w-14 object-cover">
                      <% else %>
                        <div class="h-14 w-14 flex items-center justify-center bg-gray-200">
                          <svg class="h-6 w-6 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="m2.25 15.75 5.159-5.159a2.25 2.25 0 0 1 3.182 0l5.159 5.159m-1.5-1.5 1.409-1.409a2.25 2.25 0 0 1 3.182 0l2.909 2.909M3.75 21h16.5A2.25 2.25 0 0 0 22.5 18.75V5.25A2.25 2.25 0 0 0 20.25 3H3.75A2.25 2.25 0 0 0 1.5 5.25v13.5A2.25 2.25 0 0 0 3.75 21Z" />
                          </svg>
                        </div>
                      <% end %>
                    </div>
                    <div class="ml-4">
                      <div class="text-sm font-bold text-gray-900"><%= incentive.name %></div>
                      <% if incentive.description.present? %>
                        <div class="text-sm text-gray-500"><%= truncate(incentive.description, length: 40) %></div>
                      <% end %>
                    </div>
                  </div>
                </td>

                <%# Point Cost %>
                <td class="px-6 py-4 whitespace-nowrap text-center text-sm font-medium text-gray-500">
                  <%= number_with_delimiter(incentive.point_cost) %>
                </td>

                <%# Team/Individual badge %>
                <td class="px-6 py-4 whitespace-nowrap text-center">
                  <% if incentive.team? %>
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-normal bg-indigo-600/25 text-indigo-700">
                      Team
                    </span>
                  <% else %>
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-normal bg-yellow-400/25 text-yellow-800">
                      Individual
                    </span>
                  <% end %>
                </td>

                <%# Status badge %>
                <td class="px-6 py-4 whitespace-nowrap text-center">
                  <% if incentive.active? %>
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-normal bg-cyan-400/25 text-teal-800">
                      Active
                    </span>
                  <% else %>
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-normal bg-red-400/55 text-red-900">
                      Inactive
                    </span>
                  <% end %>
                </td>

                <%# Edit action %>
                <td class="px-6 py-4 whitespace-nowrap text-right">
                  <% if current_user.can?(:edit, :incentives) %>
                    <%= link_to edit_incentive_path(incentive), class: "text-gray-400 hover:text-indigo-600" do %>
                      <svg class="h-5 w-5 inline-block" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0 1 15.75 21H5.25A2.25 2.25 0 0 1 3 18.75V8.25A2.25 2.25 0 0 1 5.25 6H10" />
                      </svg>
                    <% end %>
                  <% end %>
                </td>
              </tr>
            <% end %>
          <% end %>
        </tbody>
      </table>
    </div>

    <%# Pagination %>
    <div class="mt-4">
      <%= paginate @incentives %>
    </div>
  </div>
</div>
