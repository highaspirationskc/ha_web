<div data-controller="image-picker" data-image-picker-category-value="incentive" data-image-picker-media-type-value="image">
<%= form_with(model: incentive) do |form| %>
  <% if incentive.errors.any? %>
    <div class="mb-4 rounded-md bg-red-50 p-4">
      <div class="flex">
        <div class="ml-3">
          <h3 class="text-sm font-medium text-red-800">
            <%= pluralize(incentive.errors.count, "error") %> prohibited this incentive from being saved:
          </h3>
          <div class="mt-2 text-sm text-red-700">
            <ul role="list" class="list-disc pl-5 space-y-1">
              <% incentive.errors.each do |error| %>
                <li><%= error.full_message %></li>
              <% end %>
            </ul>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <div class="bg-white shadow rounded-lg p-6">
    <div class="md:grid md:grid-cols-3 md:gap-8">
      <%# Left side: section info %>
      <div class="md:col-span-1">
        <h3 class="text-base font-medium text-gray-900">Incentive Information</h3>
        <p class="mt-1 text-sm text-gray-500">Enter the details for this incentive.</p>
      </div>

      <%# Right side: form fields %>
      <div class="mt-5 md:mt-0 md:col-span-2 space-y-5">
        <%# Name %>
        <div>
          <label for="incentive_name" class="block text-xs font-medium text-gray-500">Name</label>
          <%= form.text_field :name, class: "mt-1 block w-full rounded border border-black/10 bg-white px-3 py-1.5 text-sm focus:border-indigo-500 focus:ring-indigo-500" %>
        </div>

        <%# Description %>
        <div>
          <label for="incentive_description" class="block text-xs font-medium text-gray-500">Description</label>
          <%= form.text_field :description, class: "mt-1 block w-full rounded border border-black/10 bg-white px-3 py-1.5 text-sm focus:border-indigo-500 focus:ring-indigo-500" %>
        </div>

        <%# Cost, Image, Type, Status row %>
        <div class="grid grid-cols-4 gap-6">
          <%# Cost %>
          <div>
            <label for="incentive_point_cost" class="block text-xs font-medium text-gray-500">Cost</label>
            <%= form.number_field :point_cost, min: 1, class: "mt-1 block w-20 rounded border border-black/10 bg-white px-3 py-1.5 text-sm focus:border-indigo-500 focus:ring-indigo-500" %>
          </div>

          <%# Image %>
          <div>
            <label class="block text-xs font-medium text-gray-500">Image</label>
            <div class="mt-1 flex items-center gap-3">
              <%= form.hidden_field :image_id, data: { image_picker_target: "input" } %>

              <%# Preview (shown when image selected) %>
              <div data-image-picker-target="preview" class="<%= 'hidden' unless incentive.image.present? %>">
                <div class="h-10 w-10 rounded bg-gray-200 overflow-hidden">
                  <% if incentive.image.present? %>
                    <img src="<%= incentive.image.thumbnail_url %>" data-image-picker-target="previewImage" class="h-10 w-10 object-cover" alt="">
                  <% else %>
                    <img src="" data-image-picker-target="previewImage" class="h-10 w-10 object-cover" alt="">
                  <% end %>
                </div>
              </div>

              <%# Placeholder (shown when no image) %>
              <div data-image-picker-target="placeholder" class="<%= 'hidden' if incentive.image.present? %>">
                <div class="h-10 w-10 rounded bg-black/10 flex items-center justify-center">
                  <svg class="h-5 w-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m2.25 15.75 5.159-5.159a2.25 2.25 0 0 1 3.182 0l5.159 5.159m-1.5-1.5 1.409-1.409a2.25 2.25 0 0 1 3.182 0l2.909 2.909M3.75 21h16.5A2.25 2.25 0 0 0 22.5 18.75V5.25A2.25 2.25 0 0 0 20.25 3H3.75A2.25 2.25 0 0 0 1.5 5.25v13.5A2.25 2.25 0 0 0 3.75 21Z" />
                  </svg>
                </div>
              </div>

              <button type="button" data-action="click->image-picker#openModal" class="text-xs font-normal text-indigo-600 hover:text-indigo-800">
                Add Image
              </button>
            </div>
          </div>

          <%# Type (radio) %>
          <div>
            <label class="block text-xs font-medium text-gray-500">Type</label>
            <div class="mt-1 space-y-2">
              <label class="flex items-center gap-2 text-xs font-medium text-gray-500 cursor-pointer">
                <%= form.radio_button :incentive_type, "individual", class: "h-4 w-4 text-indigo-600 border-gray-300 focus:ring-indigo-500" %>
                Individual
              </label>
              <label class="flex items-center gap-2 text-xs font-medium text-gray-500 cursor-pointer">
                <%= form.radio_button :incentive_type, "team", class: "h-4 w-4 text-indigo-600 border-gray-300 focus:ring-indigo-500" %>
                Team
              </label>
            </div>
          </div>

          <%# Status (checkbox) %>
          <div>
            <label class="block text-xs font-medium text-gray-500">Status</label>
            <div class="mt-1">
              <label class="flex items-center gap-2 text-xs font-medium text-gray-500 cursor-pointer">
                <%= form.check_box :active, class: "h-4 w-4 rounded text-indigo-600 border-gray-300 focus:ring-indigo-500" %>
                Active
              </label>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <%# Actions %>
  <div class="flex justify-end gap-3 mt-4">
    <%= link_to "Cancel", incentives_path, class: "inline-flex items-center px-6 py-1.5 text-xs font-medium rounded bg-white text-gray-900 shadow-sm ring-1 ring-gray-200 hover:bg-gray-50" %>
    <%= form.submit incentive.persisted? ? "Save Changes" : "Create Incentive", class: "inline-flex items-center px-6 py-1.5 text-xs font-bold rounded bg-indigo-600 text-white hover:bg-indigo-700 cursor-pointer" %>
  </div>
<% end %>

<%# Image picker modal (outside form but inside controller div) %>
<div data-image-picker-target="modal" class="hidden fixed inset-0 z-50 overflow-y-auto">
  <div data-image-picker-target="backdrop" data-action="click->image-picker#closeOnBackdrop" class="fixed inset-0 bg-black/50 transition-opacity">
    <div class="flex min-h-full items-center justify-center p-4">
      <div class="relative transform overflow-hidden rounded-lg bg-white text-left shadow-xl transition-all sm:my-8 sm:w-full sm:max-w-lg">
        <div class="bg-white">
          <div class="flex items-center justify-between px-4 py-3 border-b border-gray-200">
            <h3 class="text-lg font-semibold text-gray-900">Select Image</h3>
            <button type="button" data-action="click->image-picker#closeModal" class="text-gray-400 hover:text-gray-500">
              <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
              </svg>
            </button>
          </div>
          <div data-image-picker-target="modalContent" class="max-h-96 overflow-y-auto">
            <p class="p-4 text-center text-gray-500">Loading...</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
</div>
