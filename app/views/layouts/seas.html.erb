<!DOCTYPE html>
<html class="h-full bg-gray-50">
  <head>
    <title><%= content_for(:title) || "SEAS Evaluation - High Aspirations" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="apple-touch-icon" href="/icon.png">

    <link rel="stylesheet" href="https://rsms.me/inter/inter.css" />

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="h-full">
    <main class="min-h-full">
      <div class="flex justify-center py-6 px-4">
        <img src="/icon.png" alt="High Aspirations" class="h-12 w-12">
      </div>
      <div>
        <% if flash[:alert].present? %>
          <div class="max-w-2xl mx-auto px-4 mb-4">
            <div class="rounded-md bg-red-50 p-4">
              <p class="text-sm text-red-700"><%= flash[:alert] %></p>
            </div>
          </div>
        <% end %>
        <% if flash[:notice].present? %>
          <div class="max-w-2xl mx-auto px-4 mb-4">
            <div class="rounded-md bg-green-50 p-4">
              <p class="text-sm text-green-700"><%= flash[:notice] %></p>
            </div>
          </div>
        <% end %>
        <%= yield %>
      </div>
    </main>
  </body>
</html>
