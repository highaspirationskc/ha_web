<div class="max-w-7xl mx-auto py-6 sm:px-6 lg:px-8">
  <div class="px-4 py-6 sm:px-0">
    <div class="flex justify-between items-center mb-6">
      <h1 class="text-3xl font-bold text-gray-900">Dashboard</h1>
      <% if @current_season %>
        <span class="px-3 py-1 text-sm font-semibold rounded-full bg-indigo-100 text-indigo-800">
          <%= @current_season.name %> Season
        </span>
      <% end %>
    </div>

    <% if @current_season %>
      <div class="mt-6">
        <div class="flex justify-between items-center mb-4">
          <h2 class="text-xl font-semibold text-gray-900">Team Leaderboard</h2>
          <%= link_to "View All", teams_path, class: "text-sm font-medium text-indigo-600 hover:text-indigo-900" %>
        </div>
        <div class="flex flex-col">
          <div class="-my-2 overflow-x-auto sm:-mx-6 lg:-mx-8">
            <div class="py-2 align-middle inline-block min-w-full sm:px-6 lg:px-8">
              <div class="shadow overflow-hidden border-b border-gray-200 sm:rounded-lg">
                <table class="min-w-full divide-y divide-gray-200">
                  <thead class="bg-gray-50">
                    <tr>
                      <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                        Rank
                      </th>
                      <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                        Team
                      </th>
                      <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                        Members
                      </th>
                      <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                        Total Points
                      </th>
                      <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                        Total Hours
                      </th>
                    </tr>
                  </thead>
                  <tbody class="bg-white divide-y divide-gray-200">
                    <% if @team_standings.any? %>
                      <%
                        # Calculate ranks with tie handling (dense ranking)
                        current_rank = 1
                        previous_points = nil
                      %>
                      <% @team_standings.each_with_index do |standing, index| %>
                        <%
                          # Increment rank only if points changed (dense ranking)
                          if previous_points && standing[:points] < previous_points
                            current_rank += 1
                          end
                          previous_points = standing[:points]
                        %>
                        <tr class="<%= 'bg-yellow-50' if current_rank == 1 %>">
                          <td class="px-6 py-4 whitespace-nowrap">
                            <div class="flex items-center">
                              <% if current_rank == 1 %>
                                <span class="text-2xl">🥇</span>
                              <% elsif current_rank == 2 %>
                                <span class="text-2xl">🥈</span>
                              <% elsif current_rank == 3 %>
                                <span class="text-2xl">🥉</span>
                              <% else %>
                                <span class="text-sm font-medium text-gray-900"><%= current_rank %></span>
                              <% end %>
                            </div>
                          </td>
                          <td class="px-6 py-4 whitespace-nowrap">
                            <%= link_to team_path(standing[:team]), class: "hover:opacity-80" do %>
                              <%= team_color_badge(standing[:team]) %>
                            <% end %>
                          </td>
                          <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                            <%= standing[:member_count] %> <%= "member".pluralize(standing[:member_count]) %>
                          </td>
                          <td class="px-6 py-4 whitespace-nowrap">
                            <div class="text-2xl font-bold text-gray-900"><%= standing[:points] %></div>
                            <div class="text-xs text-gray-500">points</div>
                          </td>
                          <td class="px-6 py-4 whitespace-nowrap">
                            <div class="text-2xl font-bold text-gray-900"><%= standing[:hours] %></div>
                            <div class="text-xs text-gray-500">hours</div>
                          </td>
                        </tr>
                      <% end %>
                    <% else %>
                      <tr>
                        <td colspan="5" class="px-6 py-4 text-center text-sm text-gray-500">No team data for this season</td>
                      </tr>
                    <% end %>
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Top Mentees Section -->
      <div class="mt-8 grid grid-cols-1 gap-6 lg:grid-cols-2">
        <!-- Top Season Mentees -->
        <div>
          <h2 class="text-xl font-semibold text-gray-900 mb-4">Top Mentees by Points</h2>
          <div class="bg-white shadow overflow-hidden sm:rounded-lg">
            <ul class="divide-y divide-gray-200">
              <% if @top_season_mentees.any? %>
                <% @top_season_mentees.each_with_index do |mentee_data, index| %>
                  <li class="<%= 'bg-yellow-50' if index == 0 %>">
                    <div class="px-4 py-4 flex items-center sm:px-6">
                      <div class="min-w-0 flex-1 sm:flex sm:items-center sm:justify-between">
                        <div class="flex items-center">
                          <% if index == 0 %>
                            <span class="text-3xl mr-3">🥇</span>
                          <% elsif index == 1 %>
                            <span class="text-3xl mr-3">🥈</span>
                          <% elsif index == 2 %>
                            <span class="text-3xl mr-3">🥉</span>
                          <% else %>
                            <span class="text-lg font-medium text-gray-500 mr-3 w-8"><%= index + 1 %></span>
                          <% end %>
                          <div>
                            <%= link_to user_path(mentee_data[:user]), class: "text-sm font-medium text-indigo-600 hover:text-indigo-900" do %>
                              <%= mentee_data[:user].first_name %> <%= mentee_data[:user].last_name %>
                            <% end %>
                            <div class="text-sm text-gray-500">
                              <% if mentee_data[:user].mentee&.team %>
                                <%= team_color_badge(mentee_data[:user].mentee.team) %>
                              <% end %>
                            </div>
                          </div>
                        </div>
                        <div class="mt-4 flex-shrink-0 sm:mt-0 sm:ml-5 text-right">
                          <div class="text-2xl font-bold text-gray-900"><%= mentee_data[:points] %></div>
                          <div class="text-xs text-gray-500">points</div>
                        </div>
                      </div>
                    </div>
                  </li>
                <% end %>
              <% else %>
                <li class="px-4 py-4 text-center text-sm text-gray-500">No mentee activity this season</li>
              <% end %>
            </ul>
          </div>
        </div>

        <!-- Top Week Mentees by Service Hours -->
        <div>
          <h2 class="text-xl font-semibold text-gray-900 mb-4">Top Mentees by Service Hours</h2>
          <div class="bg-white shadow overflow-hidden sm:rounded-lg">
            <ul class="divide-y divide-gray-200">
              <% if @top_service_hours_mentees.any? %>
                <% @top_service_hours_mentees.each_with_index do |mentee_data, index| %>
                  <li class="<%= 'bg-yellow-50' if index == 0 %>">
                    <div class="px-4 py-4 flex items-center sm:px-6">
                      <div class="min-w-0 flex-1 sm:flex sm:items-center sm:justify-between">
                        <div class="flex items-center">
                          <% if index == 0 %>
                            <span class="text-3xl mr-3">🥇</span>
                          <% elsif index == 1 %>
                            <span class="text-3xl mr-3">🥈</span>
                          <% elsif index == 2 %>
                            <span class="text-3xl mr-3">🥉</span>
                          <% else %>
                            <span class="text-lg font-medium text-gray-500 mr-3 w-8"><%= index + 1 %></span>
                          <% end %>
                          <div>
                            <%= link_to user_path(mentee_data[:user]), class: "text-sm font-medium text-indigo-600 hover:text-indigo-900" do %>
                              <%= mentee_data[:user].first_name %> <%= mentee_data[:user].last_name %>
                            <% end %>
                            <div class="text-sm text-gray-500">
                              <% if mentee_data[:user].mentee&.team %>
                                <%= team_color_badge(mentee_data[:user].mentee.team) %>
                              <% end %>
                            </div>
                          </div>
                        </div>
                        <div class="mt-4 flex-shrink-0 sm:mt-0 sm:ml-5">
                          <div class="text-2xl font-bold text-gray-900"><%= mentee_data[:hours] %></div>
                          <div class="text-xs text-gray-500 text-right">hours</div>
                        </div>
                      </div>
                    </div>
                  </li>
                <% end %>
              <% else %>
                <li class="px-4 py-4 text-center text-sm text-gray-500">No service hours logged this season</li>
              <% end %>
            </ul>
          </div>
        </div>
      </div>

      <!-- SEAS Self Evaluations -->
      <div class="mt-8">
        <h2 class="text-xl font-semibold text-gray-900 mb-4">SEAS Self Evaluations</h2>
        <div class="bg-white shadow overflow-hidden sm:rounded-lg">
          <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-50">
              <tr>
                <% unless current_user.mentee? %>
                  <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Mentee</th>
                <% end %>
                <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Year</th>
                <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Sent</th>
                <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
                <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Action</th>
              </tr>
            </thead>
            <tbody class="bg-white divide-y divide-gray-200">
              <% if @seas_evaluations.any? %>
                <% @seas_evaluations.each do |evaluation| %>
                  <tr>
                    <% unless current_user.mentee? %>
                      <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">
                        <%= link_to user_path(evaluation.mentee.user), class: "text-indigo-600 hover:text-indigo-900" do %>
                          <%= evaluation.mentee.user.first_name %> <%= evaluation.mentee.user.last_name %>
                        <% end %>
                      </td>
                    <% end %>
                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                      <%= evaluation.evaluation_year %>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                      <%= evaluation.sent_at&.strftime("%b %d, %Y") %>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap">
                      <% case evaluation.status %>
                      <% when "pending", "in_progress" %>
                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800">Pending</span>
                      <% when "submitted" %>
                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-amber-100 text-amber-800">Awaiting Review</span>
                      <% when "in_review" %>
                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800">In Review<% if evaluation.reviewer %> by <%= evaluation.reviewer.first_name %><% end %></span>
                      <% when "reviewed" %>
                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">Completed</span>
                      <% end %>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                      <% if current_user.can?(:review, :seas_evaluations) && evaluation.reviewable? %>
                        <%= link_to "Review", review_seas_evaluation_path(evaluation), class: "text-indigo-600 hover:text-indigo-900" %>
                      <% elsif evaluation.completed? %>
                        <%= link_to "View", seas_evaluation_path(evaluation.token), class: "text-indigo-600 hover:text-indigo-900" %>
                      <% elsif !evaluation.expired? %>
                        <%= link_to "Begin", seas_evaluation_path(evaluation.token), class: "text-indigo-600 hover:text-indigo-900" %>
                      <% else %>
                        <span class="text-gray-400">Expired</span>
                      <% end %>
                    </td>
                  </tr>
                <% end %>
              <% else %>
                <tr>
                  <td colspan="<%= current_user.mentee? ? 4 : 5 %>" class="px-6 py-4 text-center text-sm text-gray-500">No SEAS evaluations</td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    <% else %>
      <div class="bg-yellow-50 border-l-4 border-yellow-400 p-4">
        <div class="flex">
          <div class="ml-3">
            <p class="text-sm text-yellow-700">
              No active Olympic season found. Please configure the Olympic seasons.
            </p>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>
